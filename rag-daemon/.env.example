# ============================================================
# Hybrid RAG Edge Daemon — Example Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to source control.
# ============================================================

# --- REQUIRED -------------------------------------------------------

# Comma-separated list of absolute paths (or a JSON array) that the daemon
# is allowed to index and apply patches to.
# Windows example:  ALLOWED_WORKSPACES=["C:\\Users\\you\\project"]
# Linux / macOS:    ALLOWED_WORKSPACES=["/home/you/project", "/home/you/libs"]
ALLOWED_WORKSPACES=[C:/Users/you/Desktop/]

# --- Optional (defaults shown) -------------------------------------

# Directories/filenames to skip during indexing (JSON array).
# Glob wildcards are supported (e.g., "*.egg-info").
IGNORE_PATTERNS=[".git", "node_modules", ".venv", "venv", "__pycache__", ".mypy_cache", ".pytest_cache", "dist", "build", ".idea", ".vscode", "*.egg-info"]

# Sentence-Transformers model to use for embedding.
# Model is downloaded once and cached locally by huggingface_hub.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Where ChromaDB stores its persistent data.
CHROMA_PERSIST_DIR=./chroma_db

# Name of the ChromaDB collection.
CHROMA_COLLECTION_NAME=code_index

# Maximum number of whitespace-delimited tokens per chunk.
CHUNK_TOKEN_LIMIT=500

# Lines of overlap between consecutive fixed-size chunks.
CHUNK_OVERLAP_LINES=5

# --- Server --------------------------------------------------------
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=info

# --- Spotify (optional) ---------------------------------------------
# Get Client ID and Secret from https://developer.spotify.com/dashboard
# In the app, add Redirect URI: http://127.0.0.1:8766/callback (use 127.0.0.1, not localhost)
# Then run: python get_spotify_refresh_token.py
# SPOTIFY_CLIENT_ID=your_client_id
# SPOTIFY_CLIENT_SECRET=your_client_secret
# SPOTIFY_REFRESH_TOKEN=your_refresh_token
